{
  "name": "opencode-copilot",
  "version": "0.1.0",
  "description": "OpenCode plugin that adapts .github/copilot/ customizations to work natively in OpenCode",
  "keywords": [
    "opencode",
    "copilot",
    "github-copilot",
    "opencode-plugin",
    "ai",
    "plugin"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SumanthAkula/opencopilot.git"
  },
  "homepage": "https://github.com/SumanthAkula/opencopilot/blob/main/README.md",
  "bugs": {
    "url": "https://github.com/SumanthAkula/opencopilot/issues"
  },
  "type": "module",
  "bin": {
    "opencopilot": "bin/install.js"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "build": "bun run scripts/bundle-plugin.ts",
    "bundle": "bun run scripts/bundle-plugin.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@opencode-ai/plugin": "latest",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "typescript": "^5.8.3"
  }
}
